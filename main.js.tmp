    if (!listEl)
      return;
    listEl.empty();
    if (this.prs.length === 0) {
      listEl.createEl("p", {
        text: "No pull requests found.",
        cls: "arcadia-hub-empty-state"
      });
      return;
    }
    for (const pr of this.prs) {
