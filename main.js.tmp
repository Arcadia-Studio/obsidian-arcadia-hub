    toggleBtns.forEach((btn) => btn.removeClass("is-active"));
    const states = ["open", "closed", "all"];
    const idx = states.indexOf(this.showState);
    (_a = toggleBtns[idx]) == null ? void 0 : _a.addClass("is-active");
  }
  renderPRList() {
